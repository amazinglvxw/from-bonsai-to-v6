---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "From Bonsai to V6", description = "How we built, broke, and rebuilt an AI agent memory system" } = Astro.props;
const base = import.meta.env.BASE_URL;
const ghRepo = "https://github.com/amazinglvxw/from-bonsai-to-v6";
---
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="bg-surface text-on-surface font-body">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-surface-variant/60 backdrop-blur-xl editorial-shadow">
    <div class="flex justify-between items-center px-8 py-6 max-w-screen-2xl mx-auto">
      <a href={base} class="text-xl font-bold tracking-tighter text-primary font-headline">From Bonsai to V6</a>
      <div class="hidden md:flex items-center gap-8">
        <a class="text-on-surface-variant/60 hover:text-primary transition-colors font-label uppercase tracking-widest text-xs" href={`${base}#milestones`}>Chronos</a>
        <a class="text-on-surface-variant/60 hover:text-primary transition-colors font-label uppercase tracking-widest text-xs" href={`${base}#articles`}>Essays</a>
        <a class="text-on-surface-variant/60 hover:text-primary transition-colors font-label uppercase tracking-widest text-xs" href={ghRepo} target="_blank">GitHub</a>
      </div>
      <div class="flex items-center gap-4">
        <a href={ghRepo} target="_blank" class="material-symbols-outlined text-primary hover:text-tertiary transition-colors cursor-pointer text-xl">code</a>
        <button class="bg-primary text-on-primary px-5 py-2 rounded-xl font-bold text-sm tracking-tight hover:shadow-[0_0_20px_rgba(194,198,214,0.15)] transition-all active:scale-95">Subscribe</button>
      </div>
    </div>
  </nav>

  <main class="relative pt-24 min-h-screen">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-primary-container w-full pt-20 pb-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center px-12 max-w-screen-2xl mx-auto border-t border-surface-variant/15 pt-12">
      <div class="mb-8 md:mb-0">
        <div class="text-lg font-black text-primary mb-2 font-headline uppercase tracking-tighter">From Bonsai to V6</div>
        <p class="font-mono text-[10px] text-surface-variant tracking-wider uppercase">A chronicle of honest engineering.</p>
      </div>
      <div class="flex flex-wrap gap-x-12 gap-y-6 mb-8 md:mb-0">
        <div class="flex flex-col gap-3">
          <span class="font-mono text-[10px] uppercase text-surface-variant mb-1">Connect</span>
          <a class="text-surface-variant hover:text-primary text-sm transition-opacity opacity-80 hover:opacity-100" href={ghRepo} target="_blank">GitHub</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="font-mono text-[10px] uppercase text-surface-variant mb-1">Language</span>
          <div class="flex items-center gap-2">
            <a class="text-tertiary text-xs font-mono" href={base}>EN</a>
            <span class="text-surface-variant">/</span>
            <a class="text-surface-variant hover:text-primary text-xs font-mono transition-colors" href={base}>中文</a>
          </div>
        </div>
      </div>
      <div class="text-right flex flex-col items-end gap-2">
        <div class="font-mono text-[10px] text-surface-variant uppercase tracking-widest">Powered by Claude + Gemini | Dual-AI</div>
        <div class="text-surface-variant text-[10px] font-mono">&copy; 2026 From Bonsai to V6</div>
      </div>
    </div>
  </footer>
</body>
</html>
